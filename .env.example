# Uber Eats Configuration
# Copy this file to .env.local and update with your actual values

# Uber API Token (从 Uber Developer Dashboard 获取)
UBER_ACCESS_TOKEN=your_actual_access_token_here

# Optional: Store ID if different from config.js
STORE_ID=your_store_id_here

# Server Port (default: 3000)
PORT=3000

# Node Environment
NODE_ENV=development
